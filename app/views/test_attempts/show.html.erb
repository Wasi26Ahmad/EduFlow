<%= vite_javascript_tag "test_attempt_show.jsx" %>

<div
  id="test-attempt-root"
  data-attempt='<%= raw(
                      {
                        id: @attempt.id,
                        expires_at: @attempt.expires_at.iso8601,
                        submit_url: test_attempt_path(@attempt),
                        csrf_token: form_authenticity_token,
                        test: {
                          title: @attempt.test.title,
                          questions: @attempt.test.questions.map do |question|
                            {
                              id: question.id,
                              content: question.content,
                              marks: question.marks,
                              question_type: question.question_type,
                              options: question.question_options.map do |option|
                                {
                                  id: option.id,
                                  content: option.content
                                }
                              end
                            }
                          end
                        }
                      }.to_json
                    ) %>'>
</div>