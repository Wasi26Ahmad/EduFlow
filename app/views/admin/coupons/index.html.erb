
<% course = @course %>

<% total_students = course.enrollments.count %>
<% approved_students = course.enrollments.approved.count %>

<% total_earned = course.payments.paid.sum(:amount) %>

<% expected_revenue = approved_students * course.price %>

<% dues = expected_revenue - total_earned %>

<% collection_rate =
     expected_revenue > 0 ?
       ((total_earned / expected_revenue) * 100).round :
       0 %>

<% total_coupons = course.coupons.count rescue 0 %>
<% active_coupons = course.coupons.where(active: true).count rescue 0 %>
<% total_coupon_uses = course.coupons.sum(:used_count) rescue 0 %>
<% total_discounts = course.payments.sum(:discount_amount) rescue 0 %>

<div style="
max-width:1450px;
  margin:48px auto;
  padding:0 24px 60px;
  font-family:Inter, system-ui, -apple-system, sans-serif;
">

  <!-- HERO -->
  <div style="
  position:relative;
    overflow:hidden;
    border-radius:36px;
    padding:38px;
    background:
      radial-gradient(circle at top right, rgba(99,102,241,0.22), transparent 28%),
        radial-gradient(circle at bottom left, rgba(59,130,246,0.18), transparent 24%),
        linear-gradient(135deg, #ffffff, #f8fafc);
    border:1px solid rgba(255,255,255,0.72);
    box-shadow:
      0 12px 40px rgba(15,23,42,0.06),
        inset 0 1px 0 rgba(255,255,255,0.9);
    margin-bottom:36px;
  ">

    <div style="
    display:flex;
      justify-content:space-between;
      align-items:center;
      gap:24px;
      flex-wrap:wrap;
    ">

      <div>

        <div style="
        display:inline-flex;
          align-items:center;
          gap:8px;
          padding:8px 15px;
          border-radius:999px;
          background:rgba(255,255,255,0.72);
          backdrop-filter:blur(12px);
          border:1px solid rgba(255,255,255,0.95);
          color:#4f46e5;
          font-size:12px;
          font-weight:800;
          letter-spacing:.4px;
          text-transform:uppercase;
          margin-bottom:18px;
        ">
          🎟 Coupon Dashboard
        </div>

        <h1 style="
        font-size:44px;
          line-height:1.05;
          font-weight:900;
          color:#0f172a;
          margin:0;
          letter-spacing:-1.6px;
        ">
          <%= course.title %>
        </h1>

        <p style="
        margin-top:16px;
          max-width:680px;
          color:#64748b;
          font-size:15px;
          line-height:1.75;
        ">
          Monitor coupon usage, revenue performance, enrollments, outstanding dues, and promotional campaigns for this course.
        </p>

      </div>

      <div style="
      min-width:240px;
        border-radius:30px;
        padding:28px;
        background:
          linear-gradient(135deg, rgba(15,23,42,0.98), rgba(30,41,59,0.95));
        color:white;
        box-shadow:
          0 18px 40px rgba(15,23,42,0.24),
            inset 0 1px 0 rgba(255,255,255,0.06);
      ">

        <div style="
        font-size:12px;
          opacity:0.7;
          letter-spacing:.6px;
          text-transform:uppercase;
          font-weight:800;
        ">
          Course Price
        </div>

        <div style="
        margin-top:10px;
          font-size:42px;
          font-weight:900;
          letter-spacing:-1px;
        ">
          ৳ <%= course.price %>
        </div>

      </div>

    </div>

  </div>

  <!-- ANALYTICS -->
  <div style="
  display:grid;
    grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));
    gap:18px;
    margin-bottom:30px;
  ">

    <!-- Students -->
    <div style="
    border-radius:26px;
      padding:24px;
      background:white;
      border:1px solid rgba(226,232,240,0.8);
      box-shadow:0 10px 24px rgba(15,23,42,0.04);
    ">

      <div style="
      font-size:12px;
        font-weight:800;
        text-transform:uppercase;
        color:#94a3b8;
      ">
        Students
      </div>

      <div style="
      margin-top:10px;
        font-size:40px;
        font-weight:900;
        color:#0f172a;
      ">
        <%= total_students %>
      </div>

    </div>

    <!-- Approved -->
    <div style="
    border-radius:26px;
      padding:24px;
      background:linear-gradient(135deg, #ecfdf5, #f0fdf4);
      border:1px solid rgba(16,185,129,0.12);
      box-shadow:0 10px 24px rgba(15,23,42,0.04);
    ">

      <div style="
      font-size:12px;
        font-weight:800;
        text-transform:uppercase;
        color:#059669;
      ">
        Approved
      </div>

      <div style="
      margin-top:10px;
        font-size:40px;
        font-weight:900;
        color:#065f46;
      ">
        <%= approved_students %>
      </div>

    </div>

    <!-- Revenue -->
    <div style="
    border-radius:26px;
      padding:24px;
      background:linear-gradient(135deg, #eff6ff, #f8fbff);
      border:1px solid rgba(59,130,246,0.14);
      box-shadow:0 10px 24px rgba(15,23,42,0.04);
    ">

      <div style="
      font-size:12px;
        font-weight:800;
        text-transform:uppercase;
        color:#2563eb;
      ">
        Revenue
      </div>

      <div style="
      margin-top:10px;
        font-size:34px;
        font-weight:900;
        color:#1d4ed8;
      ">
        ৳ <%= total_earned.to_i %>
      </div>

    </div>

    <!-- Outstanding -->
    <div style="
    border-radius:26px;
      padding:24px;
      background:linear-gradient(135deg, #fff1f2, #fef2f2);
      border:1px solid rgba(239,68,68,0.12);
      box-shadow:0 10px 24px rgba(15,23,42,0.04);
    ">

      <div style="
      font-size:12px;
        font-weight:800;
        text-transform:uppercase;
        color:#dc2626;
      ">
        Outstanding
      </div>

      <div style="
      margin-top:10px;
        font-size:34px;
        font-weight:900;
        color:#b91c1c;
      ">
        ৳ <%= dues.to_i %>
      </div>

    </div>

  </div>

  <!-- COLLECTION -->
  <div style="
  border-radius:30px;
    padding:28px;
    background:white;
    border:1px solid rgba(226,232,240,0.8);
    box-shadow:0 10px 28px rgba(15,23,42,0.05);
    margin-bottom:30px;
  ">

    <div style="
    display:flex;
      justify-content:space-between;
      margin-bottom:14px;
      align-items:center;
    ">

      <div style="
      font-size:14px;
        font-weight:800;
        color:#64748b;
      ">
        Collection Rate
      </div>

      <div style="
      font-size:16px;
        font-weight:900;
        color:#0f172a;
      ">
        <%= collection_rate %>%
      </div>

    </div>

    <div style="
    height:14px;
      border-radius:999px;
      overflow:hidden;
      background:#e2e8f0;
    ">

      <div style="
      width:<%= collection_rate %>%;
        height:100%;
        border-radius:999px;
        background:linear-gradient(90deg, #2563eb, #4f46e5);
      "></div>

    </div>

  </div>

  <!-- COUPON ANALYTICS -->
  <div style="
  border-radius:32px;
    padding:30px;
    background:
      linear-gradient(
        135deg,
          rgba(255,255,255,0.82),
          rgba(248,250,252,0.9)
        );
    border:1px solid rgba(255,255,255,0.95);
    box-shadow:
      0 10px 28px rgba(15,23,42,0.05),
        inset 0 1px 0 rgba(255,255,255,0.95);
  ">

    <!-- HEADER -->
    <div style="
    display:flex;
      justify-content:space-between;
      align-items:center;
      gap:20px;
      flex-wrap:wrap;
      margin-bottom:28px;
    ">

      <div>

        <div style="
        display:inline-flex;
          align-items:center;
          gap:8px;
          padding:7px 14px;
          border-radius:999px;
          background:rgba(99,102,241,0.08);
          color:#4f46e5;
          font-size:12px;
          font-weight:800;
          text-transform:uppercase;
          margin-bottom:14px;
        ">
          🎟 Coupon Analytics
        </div>

        <h2 style="
        margin:0;
          font-size:32px;
          font-weight:900;
          letter-spacing:-1px;
          color:#0f172a;
        ">
          Promotional Campaigns
        </h2>

      </div>

      <%= link_to "✨ Generate Coupon",
                  new_admin_course_coupon_path(course),
                  style: "
            padding:14px 22px;
            border-radius:18px;
            background:linear-gradient(135deg, #4f46e5, #2563eb);
            color:white;
            text-decoration:none;
            font-size:14px;
            font-weight:900;
            box-shadow:0 10px 24px rgba(79,70,229,0.24);
          "
      %>

    </div>

    <!-- ANALYTICS GRID -->
    <div style="
    display:grid;
      grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));
      gap:18px;
    ">

      <!-- Total -->
      <div style="
      border-radius:24px;
        padding:24px;
        background:linear-gradient(135deg, #eef2ff, #f5f3ff);
        border:1px solid rgba(99,102,241,0.12);
      ">

        <div style="
        font-size:12px;
          font-weight:800;
          text-transform:uppercase;
          color:#6366f1;
        ">
          Total Coupons
        </div>

        <div style="
        margin-top:10px;
          font-size:40px;
          font-weight:900;
          color:#312e81;
        ">
          <%= total_coupons %>
        </div>

      </div>

      <!-- Active -->
      <div style="
      border-radius:24px;
        padding:24px;
        background:linear-gradient(135deg, #ecfdf5, #f0fdf4);
        border:1px solid rgba(16,185,129,0.12);
      ">

        <div style="
        font-size:12px;
          font-weight:800;
          text-transform:uppercase;
          color:#059669;
        ">
          Active Coupons
        </div>

        <div style="
        margin-top:10px;
          font-size:40px;
          font-weight:900;
          color:#065f46;
        ">
          <%= active_coupons %>
        </div>

      </div>

      <!-- Uses -->
      <div style="
      border-radius:24px;
        padding:24px;
        background:linear-gradient(135deg, #eff6ff, #f8fbff);
        border:1px solid rgba(59,130,246,0.14);
      ">

        <div style="
        font-size:12px;
          font-weight:800;
          text-transform:uppercase;
          color:#2563eb;
        ">
          Total Uses
        </div>

        <div style="
        margin-top:10px;
          font-size:40px;
          font-weight:900;
          color:#1d4ed8;
        ">
          <%= total_coupon_uses %>
        </div>

      </div>

      <!-- Discount -->
      <div style="
      border-radius:24px;
        padding:24px;
        background:linear-gradient(135deg, #fff7ed, #fffbeb);
        border:1px solid rgba(249,115,22,0.14);
      ">

        <div style="
        font-size:12px;
          font-weight:800;
          text-transform:uppercase;
          color:#ea580c;
        ">
          Discounts Given
        </div>

        <div style="
        margin-top:10px;
          font-size:34px;
          font-weight:900;
          color:#c2410c;
        ">
          ৳ <%= total_discounts.to_i %>
        </div>

      </div>

    </div>

  </div>

  <!-- ACTIVE COUPONS -->
  <div style="
  margin-top:32px;
  ">

    <% active_coupon_list =
         course.coupons
               .where(active: true)
               .where("expires_at > ?", Time.current)
               .order(created_at: :desc)
    %>

    <% if active_coupon_list.any? %>

      <div style="
      display:grid;
        grid-template-columns:repeat(auto-fit, minmax(340px, 1fr));
        gap:20px;
      ">

        <% active_coupon_list.each do |coupon| %>

          <div style="
          position:relative;
            overflow:hidden;
            border-radius:30px;
            padding:26px;
            background:white;
            border:1px solid rgba(226,232,240,0.8);
            box-shadow:0 10px 28px rgba(15,23,42,0.05);
          ">

            <!-- TOP -->
            <div style="
            display:flex;
              justify-content:space-between;
              align-items:flex-start;
              gap:12px;
            ">

              <div>

                <!-- CODE -->
                <div style="
                display:inline-flex;
                  align-items:center;
                  gap:10px;
                  padding:12px 16px;
                  border-radius:18px;
                  background:
                    linear-gradient(135deg, #4f46e5, #2563eb);
                  color:white;
                  font-size:18px;
                  font-weight:900;
                  letter-spacing:1px;
                  box-shadow:
                    0 10px 24px rgba(79,70,229,0.24);
                ">
                  <%= coupon.code %>
                </div>

                <!-- DISCOUNT -->
                <div style="
                margin-top:18px;
                  font-size:34px;
                  font-weight:900;
                  color:#0f172a;
                ">

                  <% if coupon.percentage? %>
                    <%= coupon.discount_value.to_i %>% OFF
                  <% else %>
                    ৳ <%= coupon.discount_value.to_i %> OFF
                  <% end %>

                </div>

              </div>

              <!-- STATUS -->
              <div style="
              padding:8px 12px;
                border-radius:999px;
                background:#ecfdf5;
                color:#059669;
                font-size:11px;
                font-weight:900;
                text-transform:uppercase;
              ">
                Active
              </div>

            </div>

            <!-- DETAILS -->
            <div style="
            margin-top:22px;
              display:grid;
              grid-template-columns:1fr 1fr;
              gap:14px;
            ">

              <!-- Minimum -->
              <div style="
              padding:16px;
                border-radius:18px;
                background:#f8fafc;
              ">

                <div style="
                font-size:11px;
                  font-weight:800;
                  text-transform:uppercase;
                  color:#94a3b8;
                ">
                  Minimum Purchase
                </div>

                <div style="
                margin-top:8px;
                  font-size:20px;
                  font-weight:900;
                  color:#0f172a;
                ">
                  ৳ <%= coupon.minimum_purchase.to_i %>
                </div>

              </div>

              <!-- Max -->
              <div style="
              padding:16px;
                border-radius:18px;
                background:#f8fafc;
              ">

                <div style="
                font-size:11px;
                  font-weight:800;
                  text-transform:uppercase;
                  color:#94a3b8;
                ">
                  Max Discount
                </div>

                <div style="
                margin-top:8px;
                  font-size:20px;
                  font-weight:900;
                  color:#0f172a;
                ">
                  ৳ <%= coupon.max_discount.to_i %>
                </div>

              </div>

              <!-- Valid From -->
              <div style="
              padding:16px;
                border-radius:18px;
                background:#f8fafc;
              ">

                <div style="
                font-size:11px;
                  font-weight:800;
                  text-transform:uppercase;
                  color:#94a3b8;
                ">
                  Valid From
                </div>

                <div style="
                margin-top:8px;
                  font-size:15px;
                  font-weight:800;
                  color:#0f172a;
                ">
                  <%= coupon.starts_at.strftime("%d %b %Y") %>
                </div>

              </div>

              <!-- Expiry -->
              <div style="
              padding:16px;
                border-radius:18px;
                background:#fef2f2;
              ">

                <div style="
                font-size:11px;
                  font-weight:800;
                  text-transform:uppercase;
                  color:#dc2626;
                ">
                  Expires
                </div>

                <div style="
                margin-top:8px;
                  font-size:15px;
                  font-weight:800;
                  color:#b91c1c;
                ">
                  <%= coupon.expires_at.strftime("%d %b %Y") %>
                </div>

              </div>

            </div>

            <!-- FOOTER -->
            <div style="
            margin-top:22px;
              padding-top:18px;
              border-top:1px solid rgba(226,232,240,0.7);
              display:flex;
              justify-content:space-between;
              align-items:center;
              gap:12px;
              flex-wrap:wrap;
            ">

              <div>

                <div style="
                font-size:11px;
                  font-weight:800;
                  text-transform:uppercase;
                  color:#94a3b8;
                ">
                  Usage
                </div>

                <div style="
                margin-top:6px;
                  font-size:20px;
                  font-weight:900;
                  color:#0f172a;
                ">
                  <%= coupon.used_count %> / <%= coupon.usage_limit %>
                </div>

              </div>

              <div style="
              display:flex;
                gap:10px;
                flex-wrap:wrap;
              ">

                <%= link_to "Edit",
                            edit_admin_course_coupon_path(course, coupon),
                            style: "
                        padding:10px 16px;
                        border-radius:14px;
                        background:#f8fafc;
                        border:1px solid rgba(226,232,240,0.9);
                        color:#0f172a;
                        text-decoration:none;
                        font-size:13px;
                        font-weight:800;
                      "
                %>

                <%= button_to "Disable",
                              admin_course_coupon_path(course, coupon),
                              method: :delete,
                              form: {
                                data: {
                                  turbo_confirm: "Disable this coupon?"
                                }
                              },
                              style: "
                        padding:10px 16px;
                        border:none;
                        border-radius:14px;
                        background:#ef4444;
                        color:white;
                        font-size:13px;
                        font-weight:900;
                        cursor:pointer;
                      "
                %>

              </div>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <!-- EMPTY -->
      <div style="
      padding:60px 24px;
        text-align:center;
        border-radius:30px;
        background:white;
        border:1px dashed rgba(148,163,184,0.4);
      ">

        <div style="
        font-size:60px;
        ">
          🎟
        </div>

        <div style="
        margin-top:16px;
          font-size:28px;
          font-weight:900;
          color:#0f172a;
        ">
          No Active Coupons
        </div>

        <p style="
        margin-top:10px;
          color:#64748b;
          font-size:15px;
          max-width:460px;
          margin-left:auto;
          margin-right:auto;
        ">
          Create promotional campaigns and discount offers for this course.
        </p>

      </div>

    <% end %>

  </div>

</div>