<div style="
min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:40px 20px;
  font-family:Inter, system-ui, -apple-system, sans-serif;
  background:
    radial-gradient(circle at top, #eef2ff, transparent 60%),
      radial-gradient(circle at bottom, #ecfeff, transparent 55%);
">

  <!-- REGISTER CARD -->
  <div style="
  width:100%;
    max-width:500px;
    position:relative;
    overflow:hidden;
    border-radius:30px;
    padding:38px;
    background:rgba(255,255,255,0.62);
    backdrop-filter:blur(18px);
    -webkit-backdrop-filter:blur(18px);
    border:1px solid rgba(255,255,255,0.55);
    box-shadow:0 20px 60px rgba(15,23,42,0.08);
  ">

    <!-- TOP BADGE -->
    <div style="
    display:inline-flex;
      align-items:center;
      gap:8px;
      padding:7px 14px;
      border-radius:999px;
      background:rgba(16,185,129,0.12);
      color:#059669;
      font-size:12px;
      font-weight:800;
      letter-spacing:0.4px;
      margin-bottom:18px;
    ">
      ✨ CREATE ACCOUNT
    </div>

    <!-- HEADER -->
    <h1 style="
    margin:0;
      font-size:42px;
      line-height:1;
      font-weight:900;
      letter-spacing:-1.6px;
      color:#0f172a;
    ">
      Join The Platform
    </h1>

    <p style="
    margin-top:14px;
      margin-bottom:30px;
      color:#64748b;
      font-size:15px;
      line-height:1.7;
    ">
      Create your account to access courses, results, enrollments, and the academic dashboard.
    </p>

    <!-- ERRORS -->
    <div style="margin-bottom:22px;">
      <%= render "devise/shared/error_messages", resource: resource %>
    </div>

    <!-- FORM -->
    <%= form_for(resource,
                 as: resource_name,
                 url: registration_path(resource_name)) do |f| %>

      <!-- EMAIL -->
      <div style="margin-bottom:22px;">

        <%= f.label :email,
                    style: "
          display:block;
          margin-bottom:10px;
          font-size:13px;
          font-weight:800;
          color:#334155;
          letter-spacing:0.3px;
        " %>

        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          placeholder: "Enter your email",
                          style: "
          width:100%;
          padding:16px 18px;
          border-radius:18px;
          border:1px solid #dbe2ea;
          background:#f8fafc;
          font-size:14px;
          font-weight:600;
          color:#0f172a;
          outline:none;
          box-sizing:border-box;
        " %>

      </div>

      <!-- PASSWORD -->
      <div style="margin-bottom:22px;">

        <div style="
        display:flex;
          justify-content:space-between;
          align-items:center;
          gap:10px;
          flex-wrap:wrap;
          margin-bottom:10px;
        ">

          <%= f.label :password,
                      style: "
            font-size:13px;
            font-weight:800;
            color:#334155;
            letter-spacing:0.3px;
          " %>

          <% if @minimum_password_length %>

            <div style="
            font-size:12px;
              font-weight:700;
              color:#64748b;
            ">
              <%= @minimum_password_length %> characters minimum
            </div>

          <% end %>

        </div>

        <%= f.password_field :password,
                             autocomplete: "new-password",
                             placeholder: "Create a password",
                             style: "
          width:100%;
          padding:16px 18px;
          border-radius:18px;
          border:1px solid #dbe2ea;
          background:#f8fafc;
          font-size:14px;
          font-weight:600;
          color:#0f172a;
          outline:none;
          box-sizing:border-box;
        " %>

      </div>

      <!-- CONFIRM PASSWORD -->
      <div style="margin-bottom:28px;">

        <%= f.label :password_confirmation,
                    style: "
          display:block;
          margin-bottom:10px;
          font-size:13px;
          font-weight:800;
          color:#334155;
          letter-spacing:0.3px;
        " %>

        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             placeholder: "Confirm your password",
                             style: "
          width:100%;
          padding:16px 18px;
          border-radius:18px;
          border:1px solid #dbe2ea;
          background:#f8fafc;
          font-size:14px;
          font-weight:600;
          color:#0f172a;
          outline:none;
          box-sizing:border-box;
        " %>

      </div>

      <!-- SUBMIT -->
      <div>

        <%= f.submit "Create Account",
                     style: "
          width:100%;
          border:none;
          border-radius:18px;
          padding:16px 20px;
          background:linear-gradient(135deg,#2563eb,#4f46e5);
          color:white;
          font-size:15px;
          font-weight:800;
          letter-spacing:0.3px;
          cursor:pointer;
          box-shadow:0 14px 30px rgba(37,99,235,0.22);
          transition:all 0.2s ease;
        " %>

      </div>

    <% end %>

    <!-- FOOTER LINKS -->
    <div style="
    margin-top:28px;
      padding-top:24px;
      border-top:1px solid rgba(226,232,240,0.8);
      text-align:center;
      color:#64748b;
      font-size:14px;
    ">

      <%= render "devise/shared/links" %>

    </div>

  </div>

</div>