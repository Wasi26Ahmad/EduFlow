<%= vite_javascript_tag "create-test.jsx" %>

<%
  test_data = {
    course_id: @course.id,
    submit_url: teacher_course_tests_path(@course),
    csrf_token: form_authenticity_token,
    test: {
      title: @test.title,
      description: @test.description,
      start_time: @test.start_time,
      end_time: @test.end_time,
      duration_minutes: @test.duration_minutes,
      total_marks: @test.total_marks,
      published: @test.published
    }
  }
%>

<div id="create-test-root"></div>

<script id="create-test-data" type="application/json">
  <%= raw(test_data.to_json) %>
</script>